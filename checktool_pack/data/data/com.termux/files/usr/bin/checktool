#!/data/data/com.termux/files/usr/bin/bash

# CheckTool 1.2.0
# Installs tools only for lawful, authorized testing.

set -u

PREFIX="${PREFIX:-/data/data/com.termux/files/usr}"
TMPDIR="${TMPDIR:-$PREFIX/tmp}"
OPT_DIR="$PREFIX/opt/checktool"
LOG_DIR="$TMPDIR/checktool-logs"
USE_DEBIAN=0

case "${1:-}" in
  --debian|--all) USE_DEBIAN=1 ;;
  --help|-h)
    cat <<'HELP'
Usage:
  checktool            Install native Termux tools and safe upstream fallbacks.
  checktool --debian   Also install Debian/proot fallbacks for tools that are
                       unavailable natively.
HELP
    exit 0
    ;;
esac

mkdir -p "$OPT_DIR" "$LOG_DIR"

C_RESET='\033[0m'
C_GREEN='\033[1;32m'
C_RED='\033[1;31m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'

info() { printf "%b[INFO]%b %s\n" "$C_CYAN" "$C_RESET" "$*"; }
ok()   { printf "%b[ OK ]%b %s\n" "$C_GREEN" "$C_RESET" "$*"; }
warn() { printf "%b[WARN]%b %s\n" "$C_YELLOW" "$C_RESET" "$*"; }
fail() { printf "%b[FAIL]%b %s\n" "$C_RED" "$C_RESET" "$*" >&2; }

printf "%b\n" "$C_GREEN"
printf '%s\n' '=================================================='
printf '%s\n' '                  CheckTool 1.2.0'
printf '%s\n' '       Termux installer and package diagnostics'
printf '%s\n' '=================================================='
printf "%b" "$C_RESET"

if ! command -v pkg >/dev/null 2>&1; then
  fail "This program must run inside Termux."
  exit 1
fi

export DEBIAN_FRONTEND=noninteractive

rm -f "$PREFIX/etc/apt/sources.list.d"/checktool.list.bak.* 2>/dev/null || true

package_installed() {
  dpkg-query -W -f='${Status}' "$1" 2>/dev/null | grep -q '^install ok installed$'
}

package_available() {
  apt-cache show "$1" >/dev/null 2>&1
}

enable_repo() {
  local repo="$1"
  local log="$LOG_DIR/repo-$repo.log"

  if package_installed "$repo"; then
    ok "$repo is already enabled."
    return 0
  fi

  info "Enabling $repo ..."
  if pkg install -y "$repo" >"$log" 2>&1; then
    ok "$repo enabled."
    return 0
  fi

  warn "Could not enable $repo. See: $log"
  tail -n 5 "$log" 2>/dev/null || true
  return 1
}

enable_repo root-repo || true
enable_repo x11-repo || true

info "Refreshing package indexes ..."
if apt-get -o Acquire::Retries=3 update >"$LOG_DIR/apt-update.log" 2>&1; then
  ok "Package indexes updated."
else
  warn "apt update finished with errors. Last lines:"
  tail -n 12 "$LOG_DIR/apt-update.log" 2>/dev/null || true
fi

install_prerequisites() {
  local log="$LOG_DIR/prerequisites.log"
  local packages=(
    git curl ca-certificates
    python python-pip perl
    clang make pkg-config openssl libffi rust
  )
  local available=()
  local p

  for p in "${packages[@]}"; do
    package_available "$p" && available+=("$p")
  done

  if [ "${#available[@]}" -gt 0 ]; then
    pkg install -y "${available[@]}" >"$log" 2>&1 || {
      warn "Some prerequisites could not be installed. See: $log"
      tail -n 8 "$log" 2>/dev/null || true
    }
  fi
}

install_prerequisites

declare -A TOOL_LABELS=(
  [hydra]='Hydra'
  [john]='John the Ripper'
  [hashcat]='Hashcat'
  [sqlmap]='SQLmap'
  [metasploit]='Metasploit'
  [aircrack]='Aircrack-ng'
  [nikto]='Nikto'
  [impacket]='Impacket'
  [nessus]='Tenable Nessus'
  [burpsuite]='Burp Suite Pro/Community'
  [openvas]='OpenVAS Scanner'
  [zaproxy]='OWASP ZAP Proxy'
  [wireshark]='Wireshark Network Analyzer'
  [sonarqube]='SonarQube Code Analyzer'
)

declare -A TOOL_COMMANDS=(
  [hydra]='hydra'
  [john]='john'
  [hashcat]='hashcat'
  [sqlmap]='sqlmap'
  [metasploit]='msfconsole'
  [aircrack]='aircrack-ng'
  [nikto]='nikto'
  [impacket]='impacket-smbclient'
  [nessus]='nessus'
  [burpsuite]='burpsuite'
  [openvas]='openvas'
  [zaproxy]='zaproxy'
  [wireshark]='wireshark'
  [sonarqube]='sonar-scanner'
)

declare -A TOOL_PACKAGES=(
  [hydra]='hydra'
  [john]='johnripper john'
  [hashcat]='hashcat'
  [sqlmap]='sqlmap'
  [metasploit]='metasploit'
  [aircrack]='aircrack-ng'
  [nikto]='nikto'
  [impacket]='python-impacket impacket'
  [nessus]='nessus'
  [burpsuite]='burpsuite'
  [openvas]='openvas gvm'
  [zaproxy]='zaproxy zap'
  [wireshark]='wireshark-qt tshark wireshark'
  [sonarqube]='sonarqube sonar-scanner sonar-scanner-cli'
)

TOOL_ORDER=(
  hydra
  john
  hashcat
  sqlmap
  metasploit
  aircrack
  nikto
  impacket
  nessus
  burpsuite
  openvas
  zaproxy
  wireshark
  sonarqube
)

native_install() {
  local label="$1"
  local command_name="$2"
  shift 2
  local candidates=("$@")
  local package log

  if command -v "$command_name" >/dev/null 2>&1; then
    ok "$label is already installed."
    return 0
  fi

  for package in "${candidates[@]}"; do
    if ! package_available "$package"; then
      info "$label: package '$package' is not present in the enabled Termux indexes."
      continue
    fi

    log="$LOG_DIR/install-$package.log"
    info "Installing $label from Termux package '$package' ..."
    if pkg install -y "$package" >"$log" 2>&1; then
      if command -v "$command_name" >/dev/null 2>&1 || package_installed "$package"; then
        ok "$label installed from '$package'."
        return 0
      fi
    fi

    warn "$label installation failed. Last lines from $log:"
    tail -n 8 "$log" 2>/dev/null || true
  done

  return 1
}

clone_or_update() {
  local url="$1"
  local dir="$2"

  if [ -d "$dir/.git" ]; then
    git -C "$dir" pull --ff-only >/dev/null 2>&1
  else
    rm -rf "$dir"
    git clone --depth 1 "$url" "$dir" >/dev/null 2>&1
  fi
}

install_sqlmap_upstream() {
  local dir="$OPT_DIR/sqlmap"
  local wrapper="$PREFIX/bin/sqlmap"

  command -v sqlmap >/dev/null 2>&1 && return 0
  info "Installing SQLmap from its official upstream repository ..."

  if clone_or_update "https://github.com/sqlmapproject/sqlmap.git" "$dir"; then
    cat > "$wrapper" <<WRAP
#!/data/data/com.termux/files/usr/bin/bash
exec "$PREFIX/bin/python" "$dir/sqlmap.py" "\$@"
WRAP
    chmod 755 "$wrapper"
    command -v sqlmap >/dev/null 2>&1 && { ok "SQLmap installed."; return 0; }
  fi

  fail "SQLmap upstream installation failed."
  return 1
}

install_nikto_upstream() {
  local dir="$OPT_DIR/nikto"
  local wrapper="$PREFIX/bin/nikto"

  command -v nikto >/dev/null 2>&1 && return 0
  info "Installing Nikto from its official upstream repository ..."

  if clone_or_update "https://github.com/sullo/nikto.git" "$dir"; then
    cat > "$wrapper" <<WRAP
#!/data/data/com.termux/files/usr/bin/bash
exec "$PREFIX/bin/perl" "$dir/program/nikto.pl" "\$@"
WRAP
    chmod 755 "$wrapper"
    command -v nikto >/dev/null 2>&1 && { ok "Nikto installed."; return 0; }
  fi

  fail "Nikto upstream installation failed."
  return 1
}

install_impacket_pip() {
  local log="$LOG_DIR/impacket-pip.log"

  if python -c 'import impacket' >/dev/null 2>&1; then
    ok "Impacket is already installed."
    return 0
  fi

  info "Installing Impacket with Python pip ..."
  if python -m pip install --upgrade --no-cache-dir impacket >"$log" 2>&1; then
    if python -c 'import impacket' >/dev/null 2>&1; then
      ok "Impacket installed."
      return 0
    fi
  fi

  warn "Native Impacket installation failed. It can be installed by the Debian fallback."
  tail -n 12 "$log" 2>/dev/null || true
  return 1
}

find_matching_file() {
  local pattern="$1"
  find "$HOME" "$OPT_DIR" -maxdepth 5 -type f -iname "$pattern" -print -quit 2>/dev/null |
    grep -q .
}

tool_detected() {
  local key="$1"
  local command_name="${TOOL_COMMANDS[$key]}"

  command -v "$command_name" >/dev/null 2>&1 && return 0

  case "$key" in
    impacket)
      command -v python >/dev/null 2>&1 &&
        python -c 'import impacket' >/dev/null 2>&1
      ;;
    nessus)
      command -v nessuscli >/dev/null 2>&1 ||
        command -v nessusd >/dev/null 2>&1
      ;;
    burpsuite)
      find_matching_file 'burpsuite*.jar'
      ;;
    openvas)
      command -v ospd-openvas >/dev/null 2>&1 ||
        command -v gvmd >/dev/null 2>&1 ||
        command -v gsad >/dev/null 2>&1
      ;;
    zaproxy)
      command -v zap.sh >/dev/null 2>&1 ||
        find_matching_file 'ZAP*.jar'
      ;;
    wireshark)
      command -v tshark >/dev/null 2>&1
      ;;
    sonarqube)
      command -v sonar.sh >/dev/null 2>&1 ||
        find_matching_file 'sonar-scanner*'
      ;;
    *)
      return 1
      ;;
  esac
}

print_tool_guidance() {
  local key="$1"

  case "$key" in
    nessus)
      warn "Tenable Nessus has no supported native Android/Termux package."
      warn "Run Nessus on a supported Linux/Windows/macOS host or VM, then open:"
      warn "https://SERVER-IP:8834 from the Android browser. Avoid unofficial installers."
      ;;
    burpsuite)
      warn "Burp Suite was not found in the enabled Termux repositories."
      warn "Use the official PortSwigger JAR with Java and Termux:X11:"
      warn "pkg install openjdk-21 termux-x11-nightly"
      warn "java -jar /path/to/burpsuite_community.jar"
      warn "Burp Suite Professional requires a valid PortSwigger license."
      ;;
    openvas)
      warn "OpenVAS/GVM needs multiple Linux services and is not a simple native Android app."
      warn "Run Greenbone/OpenVAS in a supported Linux VM, server or container and access"
      warn "its web interface remotely. A Kali/Debian proot may be used for experiments,"
      warn "but service management and network capture can be limited under Android."
      ;;
    zaproxy)
      warn "OWASP ZAP was not found in the enabled Termux repositories."
      warn "Use the official cross-platform ZAP package with Java and Termux:X11,"
      warn "or run ZAP in daemon mode on another Linux host and connect remotely."
      ;;
    wireshark)
      warn "Wireshark was not installed. Current Termux package names are normally:"
      warn "wireshark-qt (GUI, x11-repo) or tshark (CLI, root-repo)."
      warn "For GUI use, install and start Termux:X11 before running wireshark."
      ;;
    sonarqube)
      warn "SonarQube Server is best run on a supported Linux host, VM or container."
      warn "Use SonarScanner in Termux/CI as the client and point it to that server."
      warn "A full SonarQube server depends on a supported JVM and database service."
      ;;
  esac
}

install_catalog_tool() {
  local key="$1"
  local label="${TOOL_LABELS[$key]}"
  local package
  local -a candidates=()

  if tool_detected "$key"; then
    ok "$label is already available."
    return 0
  fi

  read -r -a candidates <<< "${TOOL_PACKAGES[$key]}"

  for package in "${candidates[@]}"; do
    if ! package_available "$package"; then
      info "$label: package '$package' is not present in the enabled Termux indexes."
      continue
    fi

    if native_install "$label" "${TOOL_COMMANDS[$key]}" "$package"; then
      if [ "$key" = "wireshark" ]; then
        warn "Wireshark GUI requires a running Termux:X11 session."
      fi
      return 0
    fi
  done

  print_tool_guidance "$key"
  return 2
}

create_debian_wrapper() {
  local command_name="$1"
  local guest_command="$2"
  local wrapper="$PREFIX/bin/$command_name"

  [ -e "$wrapper" ] && return 0

  cat > "$wrapper" <<WRAP
#!/data/data/com.termux/files/usr/bin/bash
cwd="\$(pwd)"
exec proot-distro login debian --bind "\$cwd:/work" --shared-tmp -- \
  bash -lc 'cd /work && exec $guest_command "\$@"' bash "\$@"
WRAP
  chmod 755 "$wrapper"
}

install_debian_fallbacks() {
  local log="$LOG_DIR/debian-fallback.log"
  local keys=("$@")
  local key
  local -a deb_packages=()
  local package_line=""

  warn "Debian fallback can use several GB of storage."
  info "Installing proot-distro ..."

  pkg install -y proot-distro >"$log" 2>&1 || {
    fail "Could not install proot-distro."
    tail -n 10 "$log" 2>/dev/null || true
    return 1
  }

  if ! proot-distro login debian -- true >/dev/null 2>&1; then
    info "Installing Debian root filesystem ..."
    proot-distro install debian >>"$log" 2>&1 || {
      fail "Could not install Debian."
      tail -n 12 "$log" 2>/dev/null || true
      return 1
    }
  fi

  for key in "${keys[@]}"; do
    case "$key" in
      john) deb_packages+=(john) ;;
      hashcat) deb_packages+=(hashcat) ;;
      aircrack) deb_packages+=(aircrack-ng) ;;
      impacket) deb_packages+=(python3-impacket) ;;
    esac
  done

  if [ "${#deb_packages[@]}" -eq 0 ]; then
    return 0
  fi

  printf -v package_line '%q ' "${deb_packages[@]}"

  info "Installing Debian fallback packages: ${deb_packages[*]} ..."
  proot-distro login debian -- bash -lc \
    "export DEBIAN_FRONTEND=noninteractive; apt-get update && apt-get install -y $package_line" \
    >>"$log" 2>&1 || {
      fail "Debian package installation failed."
      tail -n 15 "$log" 2>/dev/null || true
      return 1
    }

  for key in "${keys[@]}"; do
    case "$key" in
      john)
        command -v john >/dev/null 2>&1 || create_debian_wrapper john john
        ;;
      hashcat)
        command -v hashcat >/dev/null 2>&1 || create_debian_wrapper hashcat hashcat
        ;;
      aircrack)
        command -v aircrack-ng >/dev/null 2>&1 ||
          create_debian_wrapper aircrack-ng aircrack-ng
        ;;
      impacket)
        command -v impacket-smbclient >/dev/null 2>&1 ||
          create_debian_wrapper impacket-smbclient impacket-smbclient
        ;;
    esac
  done

  ok "Debian fallback tools installed. Current Termux directory is mounted as /work."
}

READY=0
FAILED=0
ADVISED=0
MISSING_DEBIAN=()

for tool_key in "${TOOL_ORDER[@]}"; do
  case "$tool_key" in
    hydra)
      if native_install "${TOOL_LABELS[$tool_key]}" "${TOOL_COMMANDS[$tool_key]}" hydra; then
        READY=$((READY + 1))
      else
        FAILED=$((FAILED + 1))
      fi
      ;;

    john|hashcat|aircrack)
      read -r -a candidates <<< "${TOOL_PACKAGES[$tool_key]}"
      if native_install "${TOOL_LABELS[$tool_key]}" "${TOOL_COMMANDS[$tool_key]}" "${candidates[@]}"; then
        READY=$((READY + 1))
      else
        MISSING_DEBIAN+=("$tool_key")
      fi
      ;;

    sqlmap)
      if native_install "${TOOL_LABELS[$tool_key]}" "${TOOL_COMMANDS[$tool_key]}" sqlmap ||
         install_sqlmap_upstream; then
        READY=$((READY + 1))
      else
        FAILED=$((FAILED + 1))
      fi
      ;;

    metasploit)
      if native_install "${TOOL_LABELS[$tool_key]}" "${TOOL_COMMANDS[$tool_key]}" metasploit; then
        READY=$((READY + 1))
      else
        ADVISED=$((ADVISED + 1))
        warn "Metasploit is not available in your enabled official Termux indexes."
        warn "CheckTool will not run untrusted community installer scripts automatically."
      fi
      ;;

    nikto)
      if native_install "${TOOL_LABELS[$tool_key]}" "${TOOL_COMMANDS[$tool_key]}" nikto ||
         install_nikto_upstream; then
        READY=$((READY + 1))
      else
        FAILED=$((FAILED + 1))
      fi
      ;;

    impacket)
      read -r -a candidates <<< "${TOOL_PACKAGES[$tool_key]}"
      if native_install "${TOOL_LABELS[$tool_key]}" "${TOOL_COMMANDS[$tool_key]}" "${candidates[@]}" ||
         install_impacket_pip; then
        READY=$((READY + 1))
      else
        MISSING_DEBIAN+=("$tool_key")
      fi
      ;;

    nessus|burpsuite|openvas|zaproxy|wireshark|sonarqube)
      install_catalog_tool "$tool_key"
      catalog_status=$?
      if [ "$catalog_status" -eq 0 ]; then
        READY=$((READY + 1))
      elif [ "$catalog_status" -eq 2 ]; then
        ADVISED=$((ADVISED + 1))
      else
        FAILED=$((FAILED + 1))
      fi
      ;;
  esac
done

if [ "${#MISSING_DEBIAN[@]}" -gt 0 ]; then
  if [ "$USE_DEBIAN" -eq 1 ]; then
    if install_debian_fallbacks "${MISSING_DEBIAN[@]}"; then
      READY=$((READY + ${#MISSING_DEBIAN[@]}))
    else
      FAILED=$((FAILED + ${#MISSING_DEBIAN[@]}))
    fi
  else
    ADVISED=$((ADVISED + ${#MISSING_DEBIAN[@]}))
    warn "Unavailable natively: ${MISSING_DEBIAN[*]}"
    warn "Run 'checktool --debian' to install these through a Debian proot fallback."
  fi
fi

printf '\n%b%s%b\n' "$C_CYAN" '================ SUMMARY ================' "$C_RESET"
printf 'Ready tools: %d\n' "$READY"
printf 'Guidance-only/unavailable tools: %d\n' "$ADVISED"
printf 'Failed installations: %d\n' "$FAILED"
printf 'Logs: %s\n' "$LOG_DIR"
printf '\n'

if [ "$FAILED" -gt 0 ]; then
  exit 2
fi
