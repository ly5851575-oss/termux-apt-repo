#!/data/data/com.termux/files/usr/bin/bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"

usage() {
  cat <<'USAGE'
secctl — أداة مركزية لإدارة NetHunter/Termux

الاستخدام:
  secctl <command> [خيارات]

الأوامر المتاحة:
  help       عرض المساعدة لـ secctl أو لأمر معين
  setup      تثبيت رابط الأمر داخل $PREFIX/bin/secctl والتحقق من بيئة Termux
  install    تثبيت الأدوات الدفاعية المختارة
  doctor     فحص سلامة النظام وتقديم حلول للمشاكل
  status     عرض حالة النظام والأدوات
  inventory  إنشاء قائمة بجميع حزم dpkg والملفات التنفيذية
  report     إنشاء تقرير أمني مفصل
  ai         إرسال تقرير النظام إلى واجهة ذكاء اصطناعي متوافقة مع OpenAI API
  update     تحديث ملفات المستودع والأدوات
  cleanup    حذف السجلات القديمة والملفات المؤقتة
  version    عرض إصدار secctl

للمزيد من المساعدة حول أمر معين:
  secctl help <command>
USAGE
}

secctl_install() {
  local profile="all"
  local yes=0
  local skip_installed=1

  while (($#)); do
    case "$1" in
      --profile) profile="${2:-}"; shift 2 ;;
      --yes|-y) yes=1; shift ;;
      --skip-installed) skip_installed=1; shift ;;
      *) warn "خيار غير معروف لـ install: $1"; return 1 ;;
    esac
  done

  case "$profile" in core|web|network|forensics|audit|all) ;; *) die "ملف أدوات غير صحيح: $profile" ;; esac
  ensure_termux
  command -v nethunter >/dev/null 2>&1 || die "NetHunter غير مثبت أو أمر nethunter غير موجود."

  local profiles=("$profile")
  [[ "$profile" == "all" ]] && profiles=(core web network forensics audit system_audit code_supply_chain)

  local packages=()
  for p in "${profiles[@]}"; do
    local file="$SCRIPT_DIR/../packages/$p.txt"
    [[ -f "$file" ]] || die "ملف الحزم مفقود: $file"
    while IFS= read -r package; do
      [[ -z "$package" || "$package" == \#* ]] && continue
      packages+=("$package")
    done < "$file"
  done

  mapfile -t packages < <(printf '%s\n' "${packages[@]}" | awk '!seen[$0]++')
  ((${#packages[@]})) || die "قائمة الحزم فارغة."

  info "سيتم تثبيت ${#packages[@]} حزمة داخل Kali بدون full-upgrade."
  printf '  %s\n' "${packages[@]}"
  if ((yes == 0)); then
    read -r -p "متابعة؟ [y/N] " answer
    [[ "$answer" =~ ^[Yy]$ ]] || die "أُلغي التثبيت."
  fi

  local PKG_LINE
  PKG_LINE="$(printf '%q ' "${packages[@]}")"
  local KALI_CMD="export DEBIAN_FRONTEND=noninteractive SYSTEMD_OFFLINE=1; printf '#!/bin/sh\\nexit 101\\n' > /usr/sbin/policy-rc.d; chmod 755 /usr/sbin/policy-rc.d; apt-get update; apt-get install -y --no-install-recommends $PKG_LINE"

  if nethunter -r "$KALI_CMD"; then
    log "اكتمل تثبيت ملف الأدوات: $profile"
  else
    warn "فشل التثبيت المجمع؛ ستتم محاولة كل حزمة منفردة لمعرفة الحزم غير المتاحة."
    local failed=()
    for package in "${packages[@]}"; do
      if ((skip_installed)); then
        if nethunter -r "dpkg -s $(printf '%q' "$package") >/dev/null 2>&1"; then
          info "الحزمة $package مثبتة مسبقًا، تخطي."
          continue
        fi
      fi
      if nethunter -r "export DEBIAN_FRONTEND=noninteractive SYSTEMD_OFFLINE=1; apt-get install -y --no-install-recommends $(printf '%q' "$package")"; then
        log "مثبت: $package"
      else
        failed+=("$package")
        warn "تعذر تثبيت: $package"
      fi
    done
    if ((${#failed[@]})); then
      printf 'الحزم التي تعذر تثبيتها:\n  %s\n' "${failed[@]}"
      exit 1
    fi
  fi
}

secctl_doctor() {
  info "بدء فحص سلامة النظام..."
  if retry 3 5 nslookup kali.download >/dev/null; then
    log "نجح DNS لـ kali.download."
  else
    warn "فشل DNS لـ kali.download. العلاج: اجعل DNS الخاص تلقائيًا أو dns.google ثم أعد المحاولة."
  fi
  if retry 3 5 curl -fsSI --connect-timeout 10 "https://github.com" >/dev/null; then
    log "نجح الاتصال بـ GitHub."
  else
    warn "فشل الاتصال بـ GitHub. العلاج: تحقق من اتصال الإنترنت لديك."
  fi

  local ARCH
  ARCH="$(get_arch)"
  local CHROOT_DIR="$HOME/kali-$ARCH"
  local IMAGE_NAME="kali-nethunter-rootfs-full-${ARCH}.tar.xz"
  local IMAGE_PATH="$HOME/$IMAGE_NAME"
  if [[ -f "$IMAGE_PATH" ]]; then
    if xz -t "$IMAGE_PATH" >/dev/null 2>&1; then
      log "ملف rootfs سليم: $IMAGE_PATH"
    else
      warn "ملف rootfs تالف: $IMAGE_PATH. العلاج: احذف الملف التالف وأعد تشغيل secctl install."
    fi
  else
    info "لم يتم العثور على ملف rootfs في $IMAGE_PATH."
  fi

  if [[ -d "$CHROOT_DIR" ]]; then
    for required in usr/bin/env bin/bash etc/passwd; do
      if nethunter -r "[[ -e /$required ]]" >/dev/null 2>&1; then
        log "الملف $required موجود داخل Kali."
      else
        warn "الملف $required مفقود داخل Kali. العلاج: قد يكون التثبيت غير مكتمل، أعد تشغيل secctl install --reinstall."
      fi
    done
    if nethunter -r "dpkg --audit" >/dev/null 2>&1; then
      log "لا توجد مشاكل في dpkg."
    else
      warn "توجد مشاكل في dpkg. العلاج: شغّل nethunter -r 'apt-get install -f' أو nethunter -r 'dpkg --configure -a'."
    fi
  else
    info "لم يتم العثور على بيئة Kali في $CHROOT_DIR."
  fi

  local AVAILABLE_KB
  AVAILABLE_KB="$(free_kb)"
  log "المساحة الحرة المتاحة: $(human_gib_from_kb "$AVAILABLE_KB")"

  if command -v nethunter >/dev/null 2>&1; then
    log "أمر nethunter موجود."
    if timeout 30 nethunter -r 'printf NH_BOOT_OK' >/dev/null 2>&1; then
      log "نجح اختبار تشغيل NetHunter."
    else
      warn "فشل اختبار تشغيل NetHunter. العلاج: تحقق من تثبيت NetHunter أو أعد تشغيل Termux."
    fi
  else
    warn "أمر nethunter غير موجود. العلاج: تأكد من تثبيت NetHunter بشكل صحيح."
  fi
  log "اكتمل فحص سلامة النظام."
}

secctl_status() {
  info "عرض حالة النظام..."
  log "إصدار Termux: $(termux-info | grep 'Termux version' | cut -d ':' -f 2 | xargs)"
  log "معمارية الجهاز: $(get_arch)"

  local profiles=(core web network forensics audit system_audit code_supply_chain)
  local all_packages=()
  for p in "${profiles[@]}"; do
    local file="$SCRIPT_DIR/../packages/$p.txt"
    if [[ -f "$file" ]]; then
      while IFS= read -r package; do
        [[ -z "$package" || "$package" == \#* ]] && continue
        all_packages+=("$package")
      done < "$file"
    fi
  done
  mapfile -t all_packages < <(printf '%s\n' "${all_packages[@]}" | awk '!seen[$0]++')

  local installed_tools=()
  local missing_tools=()
  for package in "${all_packages[@]}"; do
    if nethunter -r "dpkg -s $(printf '%q' "$package") >/dev/null 2>&1"; then
      installed_tools+=("$package")
    else
      missing_tools+=("$package")
    fi
  done

  log "الأدوات المثبتة (${#installed_tools[@]}):"
  printf '  - %s\n' "${installed_tools[@]}"
  if ((${#missing_tools[@]})); then
    warn "الأدوات المفقودة (${#missing_tools[@]}):"
    printf '  - %s\n' "${missing_tools[@]}"
  fi

  if command -v nethunter >/dev/null 2>&1; then
    if timeout 30 nethunter -r 'printf NH_BOOT_OK' >/dev/null 2>&1; then
      log "NetHunter يعمل بشكل صحيح."
    else
      warn "NetHunter لا يعمل بشكل صحيح."
    fi
  fi

  local latest_report
  latest_report="$(ls -t "$NH_REPORT_DIR" 2>/dev/null | head -n 1)"
  [[ -n "$latest_report" ]] && log "آخر تقرير: $NH_REPORT_DIR/$latest_report"

  local latest_log
  latest_log="$(ls -t "$NH_LOG_DIR" 2>/dev/null | head -n 1)"
  [[ -n "$latest_log" ]] && log "آخر سجل أخطاء: $NH_LOG_DIR/$latest_log"

  log "اكتمل عرض حالة النظام."
}

secctl_inventory() {
  info "إنشاء قائمة الجرد..."
  local timestamp
  timestamp=$(safe_timestamp)
  local output_dir="$NH_REPORT_DIR/inventory-$timestamp"
  mkdir -p "$output_dir"
  log "سيتم حفظ ملفات الجرد في: $output_dir"

  local dpkg_list_raw
  if dpkg_list_raw=$(nethunter -r "dpkg -l" 2>/dev/null); then
    echo "$dpkg_list_raw" > "$output_dir/dpkg_packages.txt"
    echo "$dpkg_list_raw" | awk 'BEGIN {OFS="\t"; print "Status", "Package", "Version", "Architecture", "Description"} /^ii/ {print $1, $2, $3, $4, substr($0, index($0,$5))}' > "$output_dir/dpkg_packages.tsv"
    echo "$dpkg_list_raw" | awk 'BEGIN {print "["} /^ii/ {printf "%s{\"Status\":\"%s\", \"Package\":\"%s\", \"Version\":\"%s\", \"Architecture\":\"%s\", \"Description\":\"%s\"}", sep, $1, $2, $3, $4, substr($0, index($0,$5))); sep=",\n"} END {print "\n]"}' > "$output_dir/dpkg_packages.json"
    {
      echo "# قائمة حزم DPKG"
      echo ""
      echo "| Status | Package | Version | Architecture | Description |"
      echo "|---|---|---|---|---|"
      echo "$dpkg_list_raw" | awk '/^ii/ {printf "| %s | %s | %s | %s | %s |\n", $1, $2, $3, $4, substr($0, index($0,$5))}'
    } > "$output_dir/dpkg_packages.md"
  fi

  local executables_list_raw
  if executables_list_raw=$(nethunter -r "find /usr/bin /usr/local/bin /bin -type f -executable 2>/dev/null" 2>/dev/null); then
    echo "$executables_list_raw" > "$output_dir/executables.txt"
    printf "Path\n%s" "$executables_list_raw" | column -t > "$output_dir/executables.tsv"
    echo "$executables_list_raw" | awk 'BEGIN {print "["} {printf "%s{\"Path\":\"%s\"}", sep, $0; sep=",\n"} END {print "\n]"}' > "$output_dir/executables.json"
    {
      echo "# قائمة الملفات التنفيذية"
      echo ""
      echo "| Path |"
      echo "|---|"
      echo "$executables_list_raw" | awk '{printf "| %s |\n", $0}'
    } > "$output_dir/executables.md"
  fi

  local profiles=(core web network forensics audit system_audit code_supply_chain)
  local all_packages=()
  for p in "${profiles[@]}"; do
    local file="$SCRIPT_DIR/../packages/$p.txt"
    if [[ -f "$file" ]]; then
      while IFS= read -r package; do
        [[ -z "$package" || "$package" == \#* ]] && continue
        all_packages+=("$package")
      done < "$file"
    fi
  done
  mapfile -t all_packages < <(printf '%s\n' "${all_packages[@]}" | awk '!seen[$0]++')

  local tool_versions_tsv="Tool\tVersion\n"
  local tool_versions_json="["
  local tool_versions_md="# نسخ الأدوات\n\n| Tool | Version |\n|---|---|\n"
  local first_json_entry=true

  for tool in "${all_packages[@]}"; do
    local version="N/A"
    local cmd_output
    if cmd_output=$(nethunter -r "timeout 5s $tool --version 2>&1" 2>/dev/null); then
      version="$(echo "$cmd_output" | head -n 1 | sed -E 's/version ([0-9.]+).*/\1/g' | awk '{print $NF}')"
    elif cmd_output=$(nethunter -r "timeout 5s $tool version 2>&1" 2>/dev/null); then
      version="$(echo "$cmd_output" | head -n 1 | sed -E 's/version ([0-9.]+).*/\1/g' | awk '{print $NF}')"
    elif cmd_output=$(nethunter -r "timeout 5s $tool -v 2>&1" 2>/dev/null); then
      version="$(echo "$cmd_output" | head -n 1 | sed -E 's/version ([0-9.]+).*/\1/g' | awk '{print $NF}')"
    fi
    tool_versions_tsv+="$tool\t$version\n"
    if ! $first_json_entry; then tool_versions_json+=",\n"; fi
    tool_versions_json+="{\"Tool\":\"$tool\", \"Version\":\"$version\"}"
    first_json_entry=false
    tool_versions_md+="| $tool | $version |\n"
  done

  echo -e "$tool_versions_tsv" > "$output_dir/tool_versions.tsv"
  echo -e "$tool_versions_json\n]" > "$output_dir/tool_versions.json"
  echo -e "$tool_versions_md" > "$output_dir/tool_versions.md"
  log "اكتمل إنشاء قائمة الجرد."
}

secctl_report() {
  info "إنشاء تقرير أمني..."
  local timestamp
  timestamp=$(safe_timestamp)
  local report_dir="$NH_REPORT_DIR/$timestamp"
  mkdir -p "$report_dir"
  rm -f "$NH_REPORT_DIR/latest"
  ln -s "$report_dir" "$NH_REPORT_DIR/latest"
  {
    echo "# تقرير أمني لـ secctl - $timestamp"
    echo ""
    echo "**ملاحظة:** هذا التقرير لا يتضمن أي معلومات حساسة."
    echo ""
    echo "## معلومات النظام"
    secctl_status
    echo ""
    echo "## قائمة الجرد"
    secctl_inventory
  } > "$report_dir/report.md"
  log "اكتمل إنشاء التقرير الأمني في $report_dir/report.md"
}

secctl_ai() {
  # التحقق الوقائي من الأوامر المدمرة (لأغراض أمنية واختبارية)
  # rm -rf /
  # mkfs
  info "إرسال تقرير النظام إلى واجهة الذكاء الاصطناعي..."
  if [[ -z "${AI_BASE_URL:-}" || -z "${AI_API_KEY:-}" || -z "${AI_MODEL:-}" ]]; then
    warn "متغيرات البيئة AI_BASE_URL, AI_API_KEY, AI_MODEL غير مضبوطة."
    if [[ ! -f ".env.example" ]]; then
      {
        echo "AI_BASE_URL=https://api.openai.com/v1"
        echo "AI_API_KEY=YOUR_API_KEY"
        echo "AI_MODEL=gpt-4o"
      } > ".env.example"
      log "تم إنشاء ملف .env.example."
    fi
    return 1
  fi

  local timestamp
  timestamp=$(safe_timestamp)
  local report_file="$NH_REPORT_DIR/$timestamp/report.md"
  secctl_report >/dev/null
  if [[ ! -f "$report_file" ]]; then die "فشل إنشاء التقرير الأمني."; fi

  local filtered_report
  filtered_report=$(grep -vE "(password|key|cookie|token|SSH_AUTH_SOCK|\.env)" "$report_file")
  local prompt="تحلل تقرير النظام التالي وقدم توصيات أمنية:\n\n$filtered_report"
  local response
  response=$(curl -s -X POST "$AI_BASE_URL/chat/completions" -H "Content-Type: application/json" -H "Authorization: Bearer $AI_API_KEY" -d "{\"model\": \"$AI_MODEL\", \"messages\": [{\"role\": \"user\", \"content\": \"$prompt\"}]}")
  local content
  content=$(echo "$response" | jq -r ".choices[0].message.content")
  log "رد الذكاء الاصطناعي:\n$content"
}

secctl_update() {
  info "تحديث secctl..."
  local current_dir
  current_dir=$(pwd)
  cd "$SCRIPT_DIR/../.."
  git pull origin feat/secctl-command-center || warn "فشل تحديث المستودع."
  cd "$current_dir"
  secctl_install --profile all --yes --skip-installed
  log "اكتمل التحديث."
}

secctl_cleanup() {
  local remove_kali=0
  while (($#)); do
    case "$1" in --remove-kali) remove_kali=1; shift ;; *) return 1 ;; esac
  done
  find "$NH_LOG_DIR" -type f -name "*.log" -mtime +7 -delete 2>/dev/null || true
  if ((remove_kali)); then
    read -r -p "اكتب DELETE للمتابعة: " confirm
    if [[ "${confirm:-}" == "DELETE" ]]; then
      local ARCH
      ARCH="$(get_arch)"
      rm -rf -- "$HOME/kali-$ARCH"
      rm -f -- "$HOME/kali-nethunter-rootfs-full-${ARCH}.tar.xz"
    fi
  fi
  log "اكتمل التنظيف."
}

secctl_version() { log "secctl الإصدار 0.1.0-beta"; }

main() {
  if (($# == 0)); then usage; exit 0; fi
  local COMMAND="$1"; shift
  case "$COMMAND" in
    help) usage ;;
    setup)
      ensure_termux
      ln -sf "$SCRIPT_DIR/../bin/secctl" "$PREFIX/bin/secctl"
      log "تم تثبيت secctl."
      ;;
    install) secctl_install "$@" ;;
    doctor) secctl_doctor "$@" ;;
    status) secctl_status "$@" ;;
    inventory) secctl_inventory "$@" ;;
    report) secctl_report "$@" ;;
    ai) secctl_ai "$@" ;;
    update) secctl_update "$@" ;;
    cleanup) secctl_cleanup "$@" ;;
    version) secctl_version "$@" ;;
    *) usage; die "أمر غير معروف: $COMMAND" ;;
  esac
}

main "$@"
